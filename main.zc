import "unistd.h" as u
import "engine.zc"

fn main()
{
    let line: char[1024]
    let response: char[1024]
    let (pid, child_in, child_out) = engine_start()

    while (1) {
        printf("> ")
        fflush(stdout)

        if (!fgets(line, sizeof(line), stdin)) {
            break
        }

        if engine_get_response(line, pid, child_in, child_out, response, sizeof(response)) {
            printf("%s", response)
        } else {
            printf("The engine has terminated")
            break
        }
    }

    fclose(child_in)
    fclose(child_out)

    wait(NULL)
    return 0;
}
